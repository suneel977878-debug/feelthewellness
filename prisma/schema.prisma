generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "rhel-openssl-1.0.x", "rhel-openssl-1.1.x", "rhel-openssl-3.0.x", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "debian-openssl-1.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Product {
  id              Int         @id @default(autoincrement())
  name            String
  price           Float
  description     String
  images          String      @db.Text // Stored as JSON string
  category        String
  subcategory     String?
  features        String      // Stored as JSON string
  isNew           Boolean     @default(false)
  isBestSeller    Boolean     @default(false)
  isOnSale        Boolean     @default(false)
  discountPercent Float?
  rating          Float       @default(5.0)
  reviews         Int         @default(0)
  color           String
  silhouetteType  String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  orderItems      OrderItem[]
}

model Order {
  id              String      @id @default(uuid())
  orderId         String      @unique
  amount          Float
  date            DateTime    @default(now())
  status          String      // 'SUCCESS' | 'FAILED' | 'PENDING' | 'VERIFIED'
  deliveryStatus  String?     // 'PROCESSING' | 'SHIPPED' | 'DELIVERED'
  deliveryNote    String?
  utr             String?
  paymentApp      String?
  
  // Customer details
  customerName    String
  customerPhone   String
  customerAddress String
  
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id          Int      @id @default(autoincrement())
  orderId     String
  productId   Int
  name        String
  price       Float
  quantity    Int
  
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])
}

model PromoCode {
  id          String   @id @default(uuid())
  code        String   @unique
  discountPct Float
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model StoreConfig {
  id              Int      @id @default(1)
  ageGateEnabled  Boolean  @default(true)
  storeUpiId      String   @default("luxurydiscreet@ybl")
  paytmMid        String   @default("")
  paytmKey        String   @default("")
  paytmEnv        String   @default("SIMULATED")
  updatedAt       DateTime @updatedAt
}
